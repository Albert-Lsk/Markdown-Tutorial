---
---

<section class="section">
  <div class="container text-center max-w-4xl mx-auto">
    <!-- Overline -->
    <p class="text-sm font-medium tracking-wider uppercase text-[var(--color-terracotta)] mb-4">
      Markdown 中文教程
    </p>

    <!-- Main Headline -->
    <h1 class="font-serif-display text-[var(--text-primary)] mb-6">
      简洁优雅的<br />标记语言
    </h1>

    <!-- Subtitle -->
    <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-8" style="line-height: 1.6;">
      Markdown 是一种轻量级标记语言，让你专注于内容本身。使用简单的语法编写格式丰富的文档，适配中英文双语。
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/basic" class="btn btn-primary text-lg !px-8 !py-3">
        开始学习
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="/about" class="btn btn-secondary text-lg !px-8 !py-3">
        了解更多
      </a>
    </div>

    <!-- Code Preview -->
    <div class="mt-16 max-w-2xl mx-auto">
      <div class="card-elevated text-left">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-3 h-3 rounded-full bg-[var(--color-terracotta)]"></div>
          <div class="w-3 h-3 rounded-full bg-[var(--color-warm-sand)]"></div>
          <div class="w-3 h-3 rounded-full bg-[var(--color-border-warm)]"></div>
        </div>
        <pre class="font-mono text-sm overflow-x-auto"><code><span class="text-[var(--color-stone-gray)]"># 标题示例</span>

<span class="text-[var(--color-coral)]">**粗体文本**</span> 和 <span class="text-[var(--color-terracotta)]">*斜体文本*</span>

<span class="text-[var(--color-terracotta)]">-</span> 列表项一
<span class="text-[var(--color-terracotta)]">-</span> 列表项二

<span class="text-[var(--color-terracotta)]">[链接文字](https://example.com)</span></code></pre>
      </div>
    </div>
  </div>
</section>
