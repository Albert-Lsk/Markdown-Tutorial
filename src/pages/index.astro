---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Comments from '../components/Comments.astro';
import { BASE_PATH } from '../config';

const useCases = [
  {
    title: '把 README 写清楚',
    description: '安装步骤、运行命令、目录结构和常见问题都适合用 Markdown 交代明白。',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>'
  },
  {
    title: '沉淀团队知识',
    description: '会议纪要、排障记录、设计草稿和 SOP 都能长期维护在一份易读的纯文本里。',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>'
  },
  {
    title: '在 GitHub 协作',
    description: 'Issue、PR、Discussion、Wiki 本身就是 Markdown 的高频战场，写得清楚就能少来回沟通。',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>'
  },
  {
    title: '发布成文档站',
    description: '同一份 Markdown 内容还能继续喂给 Astro、VitePress 或 GitHub Pages 生成网站。',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>'
  }
];

const workflowSteps = [
  {
    title: '先写一份别人看得懂的 README',
    description: '先交代项目解决什么问题、怎么安装、怎么运行。让读者先活下来，再谈完整语法。',
  },
  {
    title: '优先掌握高频基础语法',
    description: '标题、列表、链接、代码块、强调和段落，已经能覆盖大多数 README、Issue 和知识库页面。',
  },
  {
    title: '按平台补扩展语法',
    description: '表格、任务列表、脚注和自动链接不是不用学，而是应当按真实需求补上。',
  },
  {
    title: '最后再挑编辑器和发布工具',
    description: '先建立稳定写作习惯，再决定 Obsidian、VS Code、Astro 还是 GitHub Pages 这套工具链。',
  },
];

const learningPaths = [
  {
    href: `${BASE_PATH}/intro`,
    title: '3 分钟上手',
    description: '先搞清楚 Markdown 在真实工作里到底解决什么问题。',
    cta: '进入入门',
  },
  {
    href: `${BASE_PATH}/basic`,
    title: '高频基础语法',
    description: '先学最常用的 6 项能力，而不是第一天背完整语法清单。',
    cta: '查看基础语法',
  },
  {
    href: `${BASE_PATH}/extended`,
    title: '扩展语法差异',
    description: '当你真的需要表格、任务列表或脚注时，再补这部分最划算。',
    cta: '查看扩展语法',
  },
  {
    href: `${BASE_PATH}/editors`,
    title: '编辑器与工具链',
    description: '最后再选择编辑器、预览方式和发布平台，避免工具先行。',
    cta: '选择编辑器',
  },
];
---

<Layout title="Markdown 实战指南 - 从 README 到文档站" description="用真实工作流学习 Markdown：README、知识库、协作讨论与文档站发布。">
  <Header />

  <main>
    <section class="section">
      <div class="container text-center max-w-5xl mx-auto">
        <p class="text-sm font-medium tracking-wider uppercase text-[var(--color-terracotta)] mb-4">
          Markdown 实战指南
        </p>

        <h1 class="font-serif-display text-[var(--text-primary)] mb-6">
          把 Markdown<br />写进真实工作流
        </h1>

        <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-8" style="line-height: 1.6;">
          这不是一份照本宣科的语法表，而是一条面向开发者、写作者和团队协作的 Markdown 使用路线。
          <strong>你会把它真正用在 README、知识库、Issue、博客和项目文档里。</strong>
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={`${BASE_PATH}/intro`} class="btn btn-primary text-lg !px-8 !py-3">
            从 3 分钟上手开始
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a href={`${BASE_PATH}/editors`} class="btn btn-secondary text-lg !px-8 !py-3">
            查看常用编辑器
          </a>
        </div>
      </div>
    </section>

    <section class="section section-tint">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-inverse)] mb-4">
            Markdown 在哪里最值钱？
          </h2>
          <p class="text-[var(--text-on-dark)] opacity-80 max-w-2xl mx-auto">
            当内容需要协作、版本控制和发布时，Markdown 的优势才真正显现。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {useCases.map((useCase) => (
            <FeatureCard {...useCase} />
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-primary)] mb-6">
              一条更像真实工作的学习路径
            </h2>
            <p class="text-[var(--text-secondary)] mb-6" style="line-height: 1.6;">
              如果你的目标是把文档写清楚，而不是背一张语法表，建议按下面顺序学习。
            </p>

            <div class="space-y-5">
              {workflowSteps.map((step, index) => (
                <div class="flex items-start gap-4">
                  <span class="flex-shrink-0 w-8 h-8 rounded-[var(--radius-comfortable)] bg-[var(--color-terracotta)] text-[var(--text-inverse)] flex items-center justify-center font-medium text-sm">
                    {index + 1}
                  </span>
                  <div>
                    <h4 class="font-medium text-[var(--text-primary)] mb-1">{step.title}</h4>
                    <p class="text-sm text-[var(--text-secondary)]">{step.description}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <a href={`${BASE_PATH}/basic`} class="btn btn-primary">
                先看高频语法
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="card-elevated">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-[var(--color-error-crimson)]"></div>
              <div class="w-3 h-3 rounded-full bg-[#fbbf24]"></div>
              <div class="w-3 h-3 rounded-full bg-[#22c55e]"></div>
            </div>
            <pre class="font-mono text-sm overflow-x-auto"><code><span class="text-[var(--color-stone-gray)]"># Markdown-Tutorial</span>

<span class="text-[var(--color-terracotta)]">## 本周目标</span>
<span class="text-[var(--color-terracotta)]">-</span> 写清安装步骤
<span class="text-[var(--color-terracotta)]">-</span> 补上贡献说明
<span class="text-[var(--color-terracotta)]">-</span> 记录已知问题

<span class="text-[var(--color-terracotta)]">## 发布路径</span>
README -&gt; Docs -&gt; GitHub Pages

<span class="text-[var(--color-terracotta)]">[在线预览](https://albert-lsk.github.io/Markdown-Tutorial/)</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-tint">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-primary)] mb-4">
            从任务出发选内容
          </h2>
          <p class="text-[var(--text-secondary)] max-w-2xl mx-auto">
            不同页面对应不同阶段：先建立上下文，再掌握高频语法，最后补平台差异和工具链。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {learningPaths.map((path) => (
            <a href={path.href} class="card group hover:border-[var(--color-terracotta)] transition-colors">
              <h3 class="font-serif text-xl font-medium text-[var(--text-primary)] mb-2 group-hover:text-[var(--color-terracotta)]">
                {path.title}
              </h3>
              <p class="text-sm text-[var(--text-secondary)] mb-4">{path.description}</p>
              <span class="text-sm text-[var(--color-terracotta)] font-medium">{path.cta} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Comments slug="home" />
  </main>

  <Footer />
</Layout>
