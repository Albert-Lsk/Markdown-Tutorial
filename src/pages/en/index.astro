---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import Comments from '../../components/Comments.astro';

const features = [
  {
    title: 'Simple to Learn',
    description: 'Use intuitive symbols to mark text formatting. Master the basics in just half an hour.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><line x1="10" y1="9" x2="8" y2="9"></line></svg>'
  },
  {
    title: 'Rich Formatting',
    description: 'Support for headings, lists, code blocks, tables, links, images and more.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>'
  },
  {
    title: 'Portable Plain Text',
    description: 'Open .md files in almost any application. Cross-platform compatibility.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>'
  },
  {
    title: 'Widely Supported',
    description: 'Supported by GitHub, StackOverflow, CSDN, Notion and many other platforms.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-terracotta)]"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>'
  }
];
---

<Layout title="Markdown Tutorial - Complete Guide" description="Learn Markdown syntax with this comprehensive tutorial. Focus on content, not formatting." lang="en">
  <Header />

  <main>
    <section class="section">
      <div class="container text-center max-w-4xl mx-auto">
        <p class="text-sm font-medium tracking-wider uppercase text-[var(--color-terracotta)] mb-4">
          Markdown Tutorial
        </p>

        <h1 class="font-serif-display text-[var(--text-primary)] mb-6">
          The Elegant<br />Markup Language
        </h1>

        <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-8" style="line-height: 1.6;">
          Markdown is a lightweight markup language that allows you to write formatted documents using plain text that is easy to read and write.
          <strong>Focus on content, not formatting</strong>.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/Markdown-Tutorial/en/intro" class="btn btn-primary text-lg !px-8 !py-3">
            Start Learning
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a href="/Markdown-Tutorial/en/editor" class="btn btn-secondary text-lg !px-8 !py-3">
            Try Editor
          </a>
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-inverse)] mb-4">
            Why Markdown?
          </h2>
          <p class="text-[var(--text-on-dark)] opacity-80 max-w-2xl mx-auto">
            Markdown makes writing simple and focused, freeing you from tedious formatting.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {features.map((feature) => (
            <FeatureCard {...feature} />
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-primary)] mb-6">
              Get Started Quickly
            </h2>
            <p class="text-[var(--text-secondary)] mb-6" style="line-height: 1.6;">
              Start learning Markdown by following the getting started guide. This guide is written for everyone, even beginners.
            </p>

            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-[var(--radius-comfortable)] bg-[var(--color-terracotta)] text-[var(--text-inverse)] flex items-center justify-center font-medium text-sm">1</span>
                <div>
                  <h4 class="font-medium text-[var(--text-primary)] mb-1">Learn Basic Syntax</h4>
                  <p class="text-sm text-[var(--text-secondary)]">Master headings, paragraphs, lists, links and more.</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-[var(--radius-comfortable)] bg-[var(--color-terracotta)] text-[var(--text-inverse)] flex items-center justify-center font-medium text-sm">2</span>
                <div>
                  <h4 class="font-medium text-[var(--text-primary)] mb-1">Learn Extended Syntax</h4>
                  <p class="text-sm text-[var(--text-secondary)]">Create tables, code blocks, task lists and more.</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-[var(--radius-comfortable)] bg-[var(--color-terracotta)] text-[var(--text-inverse)] flex items-center justify-center font-medium text-sm">3</span>
                <div>
                  <h4 class="font-medium text-[var(--text-primary)] mb-1">Choose Your Editor</h4>
                  <p class="text-sm text-[var(--text-secondary)]">Pick the Markdown editor that suits you best.</p>
                </div>
              </div>
            </div>

            <div class="mt-8">
              <a href="/Markdown-Tutorial/en/intro" class="btn btn-primary">
                View Full Tutorial
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="card-elevated">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-3 h-3 rounded-full bg-[var(--color-error-crimson)]"></div>
              <div class="w-3 h-3 rounded-full bg-[#fbbf24]"></div>
              <div class="w-3 h-3 rounded-full bg-[#22c55e]"></div>
            </div>
            <pre class="font-mono text-sm overflow-x-auto"><code><span class="text-[var(--color-stone-gray)]"># Heading 1</span>
<span class="text-[var(--color-stone-gray)]">## Heading 2</span>

<span class="text-[var(--color-terracotta)]">**This is bold**</span>

<span class="text-[var(--color-terracotta)]">-</span> First item
<span class="text-[var(--color-terracotta)]">-</span> Second item

<span class="text-[var(--color-terracotta)]">[Link text](https://example.com)</span></code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background-color: var(--color-ivory);">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="font-serif text-3xl md:text-4xl font-medium text-[var(--text-primary)] mb-4">
            Documentation
          </h2>
          <p class="text-[var(--text-secondary)] max-w-2xl mx-auto">
            A systematic learning path from basics to advanced, master Markdown step by step.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a href="/Markdown-Tutorial/en/intro" class="card group hover:border-[var(--color-terracotta)] transition-colors">
            <h3 class="font-serif text-xl font-medium text-[var(--text-primary)] mb-2 group-hover:text-[var(--color-terracotta)]">
              Getting Started
            </h3>
            <p class="text-sm text-[var(--text-secondary)] mb-4">Learn what Markdown is and why you should use it.</p>
            <span class="text-sm text-[var(--color-terracotta)] font-medium">Start Learning →</span>
          </a>

          <a href="/Markdown-Tutorial/en/basic" class="card group hover:border-[var(--color-terracotta)] transition-colors">
            <h3 class="font-serif text-xl font-medium text-[var(--text-primary)] mb-2 group-hover:text-[var(--color-terracotta)]">
              Basic Syntax
            </h3>
            <p class="text-sm text-[var(--text-secondary)] mb-4">Headings, paragraphs, lists, links and more core elements.</p>
            <span class="text-sm text-[var(--color-terracotta)] font-medium">Start Learning →</span>
          </a>

          <a href="/Markdown-Tutorial/en/extended" class="card group hover:border-[var(--color-terracotta)] transition-colors">
            <h3 class="font-serif text-xl font-medium text-[var(--text-primary)] mb-2 group-hover:text-[var(--color-terracotta)]">
              Extended Syntax
            </h3>
            <p class="text-sm text-[var(--text-secondary)] mb-4">Tables, code blocks, task lists and advanced features.</p>
            <span class="text-sm text-[var(--color-terracotta)] font-medium">Start Learning →</span>
          </a>
        </div>
      </div>
    </section>

    <Comments slug="home" />
  </main>

  <Footer />
</Layout>
