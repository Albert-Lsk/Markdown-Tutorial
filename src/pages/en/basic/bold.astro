---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Comments from '../../../components/Comments.astro';
---

<Layout title="Bold - Markdown Tutorial" description="Learn how to create bold text in Markdown." lang="en">
  <Header />

  <main>
    <section class="section section-dark">
      <div class="container">
        <div class="max-w-3xl">
          <p class="text-sm font-medium tracking-wider uppercase text-[var(--color-terracotta)] mb-4">
            Basic Syntax / Bold
          </p>
          <h1 class="font-serif-display text-[var(--text-inverse)] mb-6">Bold</h1>
          <p class="text-xl text-[var(--text-on-dark)] opacity-80" style="line-height: 1.6;">
            Use bold text to emphasize important content.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container max-w-4xl">
        <div class="prose">
          <h2>Syntax</h2>
          <p>There are two ways to create bold text in Markdown:</p>

          <h3>Using two asterisks</h3>
          <pre><code>**This is bold text**</code></pre>

          <h3>Using two underscores</h3>
          <pre><code>__This is bold text__</code></pre>

          <h2>Preview</h2>
          <div class="card">
            <p class="text-lg mb-2"><strong>This is bold text using asterisks</strong></p>
            <p class="text-lg"><strong>This is bold text using underscores</strong></p>
          </div>

          <h2>Use Cases</h2>
          <ul>
            <li>Emphasize key terms or important concepts</li>
            <li>Mark call-to-action (CTA) elements</li>
            <li>Warning messages in technical documentation</li>
          </ul>

          <h2>Nesting</h2>
          <p>Bold can be combined with italic:</p>
          <pre><code>***Bold plus italic***
**Bold + *italic***</code></pre>
        </div>
      </div>
    </section>

    <Comments slug="basic-bold" />
  </main>

  <Footer />
</Layout>
